---
import { url } from "../lib/content.js";
const { id = "search" } = Astro.props;
const bundle = url("pagefind/");
---

<div id={id} class="pagefind-search"></div>

<script is:inline define:vars={{ bundle, id }}>
  // Uses the shared loader defined in Base.astro so the index script is
  // fetched only once even when the global search modal is also present.
  window
    .loadPagefind()
    .then((PagefindUI) => {
      new PagefindUI({
        element: "#" + id,
        bundlePath: bundle,
        showSubResults: true,
        showImages: false,
        pageSize: 8,
      });
    })
    .catch(() => {
      const el = document.getElementById(id);
      if (el)
        el.innerHTML =
          '<p class="search-fallback">Search index loads after the site is built (run <code>npm run build</code>).</p>';
    });
</script>
